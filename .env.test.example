# Test Environment Variables
# Copy this file to .env.test and fill in your values

# Database - Use a separate test database
POSTGRES_PRISMA_URL="postgresql://postgres:postgres@localhost:5432/ragdb_test?schema=public&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://postgres:postgres@localhost:5432/ragdb_test?schema=public"

# OpenAI - Use test key or mock
OPENAI_API_KEY="sk-test-key"

# NextAuth.js
NEXTAUTH_SECRET="test-secret-key-for-testing-only"
NEXTAUTH_URL="http://localhost:3000"

# OAuth (GitHub) - Optional for tests
AUTH_GITHUB_ID="test-github-id"
AUTH_GITHUB_SECRET="test-github-secret"

# Inngest (Background jobs) - Use test keys
INNGEST_EVENT_KEY="test"
INNGEST_SIGNING_KEY="test-signing-key"

# Test-specific settings
CI="false"
NODE_ENV="test"

# Playwright settings
PLAYWRIGHT_BASE_URL="http://localhost:3000"

# Vitest settings
VITEST_COVERAGE="true"
