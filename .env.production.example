# ============================================
# RAG Starter Kit - Production Environment
# ============================================
# Copy this file to .env.production and fill in your values
# DO NOT commit .env.production to version control

# --------------------------------------------
# Database (PostgreSQL + pgvector on Vercel or external)
# --------------------------------------------
# Primary connection string (with connection pooling for serverless)
POSTGRES_PRISMA_URL="postgres://user:password@your-db-host:5432/ragdb?pgbouncer=true&connect_timeout=15"

# Direct connection for migrations (no pooling)
POSTGRES_URL_NON_POOLING="postgres://user:password@your-db-host:5432/ragdb"

# Alternative: Vercel Postgres (auto-configured when using Vercel integrations)
# POSTGRES_PRISMA_URL="${VERCEL_POSTGRES_URL}"
# POSTGRES_URL_NON_POOLING="${VERCEL_POSTGRES_URL_NON_POOLING}"

# --------------------------------------------
# NextAuth.js Configuration
# --------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-production-secret-key-min-32-characters-long"

# Will be auto-set by Vercel: https://your-project.vercel.app
NEXTAUTH_URL="${VERCEL_URL}"

# OAuth Providers - Configure at least one for production
# GitHub OAuth: https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Google OAuth: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --------------------------------------------
# OpenAI API (Required for LLM and Embeddings)
# --------------------------------------------
OPENAI_API_KEY="sk-your-production-openai-api-key"

# Optional: Azure OpenAI configuration
# OPENAI_BASE_URL="https://your-resource.openai.azure.com/openai/deployments/your-deployment"
# AZURE_OPENAI_API_KEY=""

# --------------------------------------------
# Vector Search Configuration
# --------------------------------------------
# Embedding model dimensions (1536 for text-embedding-3-small, 3072 for text-embedding-3-large)
EMBEDDING_DIMENSIONS="1536"

# Similarity threshold for vector search (0.0 - 1.0)
DEFAULT_SIMILARITY_THRESHOLD="0.7"

# Max chunks to retrieve per query
MAX_RETRIEVED_CHUNKS="5"

# --------------------------------------------
# Application Settings
# --------------------------------------------
# Default LLM model
DEFAULT_MODEL="gpt-4o-mini"

# Max file upload size in MB
MAX_UPLOAD_SIZE_MB="50"

# Default chunk size for document processing
DEFAULT_CHUNK_SIZE="1000"

# Default chunk overlap
DEFAULT_CHUNK_OVERLAP="200"

# --------------------------------------------
# Rate Limiting (Upstash Redis - Recommended for Production)
# --------------------------------------------
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"

# --------------------------------------------
# Monitoring & Error Tracking (Highly Recommended)
# --------------------------------------------
# Sentry for error tracking: https://sentry.io
SENTRY_DSN="https://your-sentry-dsn.ingest.sentry.io/project-id"
NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn.ingest.sentry.io/project-id"

# PostHog for analytics: https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY="phc_your-project-key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# --------------------------------------------
# File Storage (Optional - for production file uploads)
# --------------------------------------------
# AWS S3 or S3-compatible (Cloudflare R2, MinIO, etc.)
S3_ENDPOINT="https://s3.amazonaws.com"
S3_BUCKET="your-bucket-name"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_REGION="us-east-1"

# --------------------------------------------
# Inngest (Background Jobs - Optional)
# --------------------------------------------
INNGEST_SIGNING_KEY="signkey-prod-your-key"
INNGEST_EVENT_KEY="test"

# --------------------------------------------
# Security Settings
# --------------------------------------------
# Enable secure cookie settings
COOKIE_SECURE="true"

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS="https://your-domain.com,https://app.your-domain.com"

# API rate limit requests per minute
API_RATE_LIMIT_PER_MINUTE="60"
