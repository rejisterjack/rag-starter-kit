# =============================================================================
# RAG Starter Kit — Production Environment
# =============================================================================
# Copy this file to .env.production and fill in your values.
# NEVER commit .env.production to version control.
#
# Deployment options:
#   Docker:  docker compose -f docker-compose.prod.yml up -d
#   Vercel:  set these as environment variables in the Vercel dashboard
# =============================================================================

# =============================================================================
# Database (PostgreSQL 16 + pgvector)
# =============================================================================
# Used by the Prisma pg adapter at runtime (can point to a pgbouncer pool)
DATABASE_URL="postgresql://user:password@your-db-host:5432/ragdb"

# Used by Prisma Migrate CLI — must be a DIRECT (non-pooled) connection
DATABASE_URL_UNPOOLED="postgresql://user:password@your-db-host:5432/ragdb"

# ── Vercel Postgres / Neon ────────────────────────────────────────────────────
# If using Vercel Postgres (Neon), the integration sets these automatically.
# Map them like this in your Vercel project settings:
#   DATABASE_URL          = $POSTGRES_URL          (pooled via pgbouncer)
#   DATABASE_URL_UNPOOLED = $POSTGRES_URL_NON_POOLING (direct connection)

# ── Docker Compose (self-hosted) ─────────────────────────────────────────────
# When using docker-compose.prod.yml, DATABASE_URL is auto-constructed from
# POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB if not set explicitly.
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="change-me-strong-password"
POSTGRES_DB="ragdb"

# =============================================================================
# NextAuth.js v5 (Auth.js)
# =============================================================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-production-secret-key-min-32-characters-long"

# Set to your public domain (auto-set by Vercel as VERCEL_URL)
NEXTAUTH_URL="https://your-domain.com"

# =============================================================================
# OAuth Providers
# =============================================================================
# GitHub OAuth — https://github.com/settings/developers
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# =============================================================================
# OpenAI (Required)
# =============================================================================
OPENAI_API_KEY="sk-your-production-openai-api-key"

# Optional: Azure OpenAI
# OPENAI_BASE_URL="https://your-resource.openai.azure.com/openai/deployments/your-deployment"

# =============================================================================
# Vector Search Configuration
# =============================================================================
EMBEDDING_DIMENSIONS="1536"
DEFAULT_SIMILARITY_THRESHOLD="0.7"
MAX_RETRIEVED_CHUNKS="5"

# =============================================================================
# Application Settings
# =============================================================================
DEFAULT_MODEL="gpt-4o-mini"
MAX_UPLOAD_SIZE_MB="50"
DEFAULT_CHUNK_SIZE="1000"
DEFAULT_CHUNK_OVERLAP="200"
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Generate with: openssl rand -base64 32
INTERNAL_API_KEY="your-internal-api-key-min-32-characters-long"
INTERNAL_SECRET="your-internal-secret-for-sse"

# =============================================================================
# Rate Limiting
# =============================================================================
# Option A: Upstash Redis (recommended for serverless / Vercel)
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"

# Option B: Self-hosted Redis (used by docker-compose.prod.yml automatically)
# REDIS_URL="redis://redis:6379"

API_RATE_LIMIT_PER_MINUTE="60"

# =============================================================================
# S3-Compatible Object Storage
# =============================================================================
# AWS S3:
#   S3_ENDPOINT="https://s3.amazonaws.com"
#   S3_FORCE_PATH_STYLE="false"
#
# Cloudflare R2:
#   S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
#   S3_FORCE_PATH_STYLE="true"
#
# Self-hosted MinIO (docker-compose.prod.yml includes MinIO automatically):
#   S3_ENDPOINT="https://minio.your-domain.com"
#   S3_FORCE_PATH_STYLE="true"

S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="us-east-1"
S3_FORCE_PATH_STYLE="false"

S3_BUCKET_DOCUMENTS="documents"
S3_BUCKET_EXPORTS="exports"
S3_BUCKET_ATTACHMENTS="attachments"

# =============================================================================
# Monitoring & Error Tracking (Recommended)
# =============================================================================
# Sentry — https://sentry.io
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_RELEASE=""

# PostHog — https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
POSTHOG_API_KEY=""

# =============================================================================
# Inngest (Background Jobs)
# =============================================================================
INNGEST_SIGNING_KEY="signkey-prod-your-key"
INNGEST_EVENT_KEY=""

# =============================================================================
# Security
# =============================================================================
COOKIE_SECURE="true"
ALLOWED_ORIGINS="https://your-domain.com"

# =============================================================================
# Email (optional)
# =============================================================================
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASSWORD=""
# SMTP_FROM=""
# SMTP_SECURE="true"
# RESEND_API_KEY=""

# =============================================================================
# SAML SSO (optional — Enterprise)
# =============================================================================
# SAML_ISSUER=""
# SAML_CERT=""
# SAML_ENTRY_POINT=""
# SAML_CALLBACK_URL=""

# =============================================================================
# Feature Flags (optional)
# =============================================================================
# ENABLE_VOICE_INPUT="true"
# ENABLE_PWA="true"
# ENABLE_REALTIME_COLLAB="true"
# ENABLE_ANALYTICS="true"

# =============================================================================
# Database Backup (docker-compose.prod.yml --profile backup)
# =============================================================================
BACKUP_RETENTION_DAYS="7"
