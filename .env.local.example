# =============================================================================
# RAG Starter Kit — Local Development Environment
# =============================================================================
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and never committed.
#
# Quick start (Docker):
#   cp .env.local.example .env.local
#   # Fill in OPENAI_API_KEY and NEXTAUTH_SECRET, then:
#   make up          # starts all services
#   make db-migrate  # runs Prisma migrations inside the container
# =============================================================================

# =============================================================================
# Database (PostgreSQL 16 + pgvector)
# =============================================================================
# Used by the Prisma pg adapter at runtime (connection pool)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ragdb"

# Used by Prisma Migrate CLI (direct / unpooled connection)
# For local dev this is the same as DATABASE_URL.
# On Vercel / Neon set this to the direct (non-pooled) connection string.
DATABASE_URL_UNPOOLED="postgresql://postgres:postgres@localhost:5432/ragdb"

# =============================================================================
# OpenAI
# =============================================================================
OPENAI_API_KEY="sk-your-openai-key"

# Optional: custom base URL (Azure OpenAI, proxies, etc.)
# OPENAI_BASE_URL="https://api.openai.com/v1"

# =============================================================================
# NextAuth.js v5 (Auth.js)
# =============================================================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-min-32-chars-long-generate-with-openssl"
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# OAuth Providers
# =============================================================================
# GitHub OAuth — https://github.com/settings/developers
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# =============================================================================
# Upstash Redis (Rate Limiting — optional)
# =============================================================================
# https://upstash.com/
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# =============================================================================
# Inngest (Background Jobs)
# =============================================================================
INNGEST_EVENT_KEY="local"
INNGEST_SIGNING_KEY="signkey-test-123456789"

# =============================================================================
# S3-Compatible Object Storage (MinIO for local dev)
# =============================================================================
# Docker Compose starts MinIO automatically — no changes needed here.
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_REGION="us-east-1"
S3_FORCE_PATH_STYLE="true"

S3_BUCKET_DOCUMENTS="documents"
S3_BUCKET_EXPORTS="exports"
S3_BUCKET_ATTACHMENTS="attachments"

# MinIO console port (for reference)
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# =============================================================================
# Sentry Error Tracking (optional)
# =============================================================================
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# =============================================================================
# PostHog Analytics (optional)
# =============================================================================
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
POSTHOG_API_KEY=""
NEXT_PUBLIC_ENABLE_POSTHOG_DEV="false"

# =============================================================================
# Real-time / WebSocket
# =============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
INTERNAL_SECRET="your-internal-secret-for-sse"
INTERNAL_API_KEY="your-internal-api-key-min-32-chars-long"

# =============================================================================
# Vector Search Configuration
# =============================================================================
EMBEDDING_DIMENSIONS="1536"
DEFAULT_SIMILARITY_THRESHOLD="0.7"
MAX_RETRIEVED_CHUNKS="5"

# =============================================================================
# Application Settings
# =============================================================================
DEFAULT_MODEL="gpt-4o-mini"
MAX_UPLOAD_SIZE_MB="50"
DEFAULT_CHUNK_SIZE="1000"
DEFAULT_CHUNK_OVERLAP="200"

# =============================================================================
# Security
# =============================================================================
ENABLE_VIRUS_SCAN="false"
ALLOWED_URL_DOMAINS=""

# =============================================================================
# Ollama (Local LLM — optional)
# =============================================================================
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_CHAT_MODEL="llama3.2"
OLLAMA_EMBEDDING_MODEL="nomic-embed-text"

# =============================================================================
# Email (optional)
# =============================================================================
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="your-smtp-user"
# SMTP_PASSWORD="your-smtp-password"
# SMTP_FROM="noreply@yourdomain.com"
# SMTP_SECURE="false"
# RESEND_API_KEY="re_..."

# =============================================================================
# SAML SSO (optional)
# =============================================================================
# SAML_ISSUER=""
# SAML_CERT=""
# SAML_ENTRY_POINT=""
# SAML_CALLBACK_URL=""

# =============================================================================
# Feature Flags (optional)
# =============================================================================
# ENABLE_VOICE_INPUT="true"
# ENABLE_PWA="true"
# ENABLE_REALTIME_COLLAB="true"
