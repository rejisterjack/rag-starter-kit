# =============================================================================
# RAG Starter Kit - Environment Configuration (Development)
# =============================================================================
# Copy this file to .env.local and fill in your values

# =============================================================================
# Database (PostgreSQL with pgvector)
# =============================================================================
POSTGRES_PRISMA_URL="postgresql://postgres:postgres@localhost:5432/ragdb?schema=public&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://postgres:postgres@localhost:5432/ragdb?schema=public"

# =============================================================================
# OpenAI
# =============================================================================
OPENAI_API_KEY="sk-your-openai-key"

# Optional: Custom OpenAI base URL (for Azure, proxies, etc.)
# OPENAI_BASE_URL="https://api.openai.com/v1"

# =============================================================================
# NextAuth.js v5 (Auth.js)
# =============================================================================
NEXTAUTH_SECRET="your-secret-key-min-32-chars-long-generate-with-openssl"
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# OAuth Providers
# =============================================================================
# GitHub OAuth - https://github.com/settings/developers
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Google OAuth - https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# =============================================================================
# Upstash Redis (Rate Limiting - Optional)
# =============================================================================
# Get your credentials from https://upstash.com/
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# =============================================================================
# Inngest (Background Jobs)
# =============================================================================
INNGEST_EVENT_KEY="local"
INNGEST_SIGNING_KEY="signkey-test-123456789"

# =============================================================================
# S3-Compatible Object Storage (MinIO for Local Dev)
# =============================================================================
# For local development with Docker Compose, MinIO is automatically configured
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_REGION="us-east-1"
S3_FORCE_PATH_STYLE="true"

# Bucket names for different content types
S3_BUCKET_DOCUMENTS="documents"
S3_BUCKET_EXPORTS="exports"
S3_BUCKET_ATTACHMENTS="attachments"

# MinIO Console ports (for reference)
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# =============================================================================
# Sentry Error Tracking (Optional)
# =============================================================================
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""  # For source map uploads during build
SENTRY_ORG=""
SENTRY_PROJECT=""

# =============================================================================
# PostHog Analytics (Optional)
# =============================================================================
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
POSTHOG_API_KEY=""
NEXT_PUBLIC_ENABLE_POSTHOG_DEV="false"  # Set to "true" to enable in development

# =============================================================================
# Real-time Collaboration (WebSocket/SSE)
# =============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
INTERNAL_SECRET="your-internal-secret-for-sse"

# WebSocket server port (for standalone mode)
# WS_PORT=3001

# =============================================================================
# Vector Search Configuration
# =============================================================================
EMBEDDING_DIMENSIONS="1536"
DEFAULT_SIMILARITY_THRESHOLD="0.7"
MAX_RETRIEVED_CHUNKS="5"

# =============================================================================
# Application Settings
# =============================================================================
DEFAULT_MODEL="gpt-4o-mini"
MAX_UPLOAD_SIZE_MB="50"
DEFAULT_CHUNK_SIZE="1000"
DEFAULT_CHUNK_OVERLAP="200"

# Internal API Key for server-to-server communication
INTERNAL_API_KEY="your-internal-api-key-min-32-chars-long"

# =============================================================================
# Security Settings
# =============================================================================
ENABLE_VIRUS_SCAN="false"
ALLOWED_URL_DOMAINS=""

# =============================================================================
# Optional: Ollama (Local LLM)
# =============================================================================
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_CHAT_MODEL="llama3.2"
OLLAMA_EMBEDDING_MODEL="nomic-embed-text"

# =============================================================================
# Optional: Email (for notifications)
# =============================================================================
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="your-smtp-user"
# SMTP_PASSWORD="your-smtp-password"
# SMTP_FROM="noreply@yourdomain.com"
# SMTP_SECURE="false"

# Or use a transactional email service
# RESEND_API_KEY="re_..."

# =============================================================================
# Optional: SAML SSO
# =============================================================================
# SAML_ISSUER=""
# SAML_CERT=""
# SAML_ENTRY_POINT=""
# SAML_CALLBACK_URL=""

# =============================================================================
# Feature Flags
# =============================================================================
# ENABLE_VOICE_INPUT="true"
# ENABLE_PWA="true"
# ENABLE_REALTIME_COLLAB="true"
