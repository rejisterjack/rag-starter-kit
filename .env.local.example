# =============================================================================
# RAG Starter Kit - Environment Configuration
# =============================================================================

# =============================================================================
# Database (PostgreSQL with pgvector)
# =============================================================================
POSTGRES_PRISMA_URL="postgresql://postgres:postgres@localhost:5432/ragdb?schema=public&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://postgres:postgres@localhost:5432/ragdb?schema=public"

# =============================================================================
# OpenAI
# =============================================================================
OPENAI_API_KEY="sk-your-openai-key"

# =============================================================================
# NextAuth.js v5 (Auth.js)
# =============================================================================
NEXTAUTH_SECRET="your-secret-key-min-32-chars-long-generate-with-openssl"
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# OAuth Providers
# =============================================================================
# GitHub OAuth - https://github.com/settings/developers
AUTH_GITHUB_ID="your-github-oauth-app-id"
AUTH_GITHUB_SECRET="your-github-oauth-app-secret"

# Google OAuth - https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"

# =============================================================================
# Upstash Redis (Rate Limiting)
# =============================================================================
# Get your credentials from https://upstash.com/
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"

# =============================================================================
# Inngest (Background Jobs)
# =============================================================================
INNGEST_EVENT_KEY="local"
INNGEST_SIGNING_KEY="signkey-test-123456789"

# =============================================================================
# Security Settings
# =============================================================================
# Enable virus scanning (requires ClamAV or similar setup)
ENABLE_VIRUS_SCAN="false"

# Allowed domains for URL ingestion (comma-separated)
# Leave empty to allow all domains
ALLOWED_URL_DOMAINS="example.com,docs.example.com"

# =============================================================================
# Optional: Ollama (Local LLM)
# =============================================================================
OLLAMA_BASE_URL="http://localhost:11434/api"

# =============================================================================
# Optional: Monitoring & Analytics
# =============================================================================
# For production monitoring (Sentry, etc.)
# SENTRY_DSN="your-sentry-dsn"

# =============================================================================
# Optional: Email (for password reset)
# =============================================================================
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="your-smtp-user"
# SMTP_PASSWORD="your-smtp-password"
# FROM_EMAIL="noreply@yourdomain.com"
