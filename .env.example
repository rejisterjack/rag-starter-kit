# ============================================
# RAG Starter Kit - Environment Variables
# ============================================

# --------------------------------------------
# Database (PostgreSQL + pgvector)
# --------------------------------------------
# Primary connection string (with connection pooling for serverless)
POSTGRES_PRISMA_URL="postgres://user:password@localhost:5432/ragdb?pgbouncer=true&connect_timeout=15"

# Direct connection for migrations (no pooling)
POSTGRES_URL_NON_POOLING="postgres://user:password@localhost:5432/ragdb"

# For Vercel Postgres (auto-configured on Vercel):
# POSTGRES_PRISMA_URL="postgres://..."
# POSTGRES_URL_NON_POOLING="postgres://..."

# --------------------------------------------
# NextAuth.js Configuration
# --------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-min-32-characters-long"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (add the ones you want to use)
# GitHub
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --------------------------------------------
# AI Provider Configuration
# --------------------------------------------
# LLM Provider: "openai" | "ollama"
LLM_PROVIDER="openai"

# Embedding Provider: "openai" | "ollama"
EMBEDDING_PROVIDER="openai"

# OpenAI API
OPENAI_API_KEY="sk-your-openai-api-key"

# Optional: Custom OpenAI base URL (for Azure, proxies, etc.)
# OPENAI_BASE_URL="https://api.openai.com/v1"

# Ollama Configuration (when using Ollama provider)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_CHAT_MODEL="llama3.2"
OLLAMA_EMBEDDING_MODEL="nomic-embed-text"

# --------------------------------------------
# Vector Search Configuration
# --------------------------------------------
# Embedding model dimensions (1536 for OpenAI text-embedding-3-small)
EMBEDDING_DIMENSIONS="1536"

# Similarity threshold for vector search (0.0 - 1.0)
DEFAULT_SIMILARITY_THRESHOLD="0.7"

# Max chunks to retrieve per query
MAX_RETRIEVED_CHUNKS="5"

# --------------------------------------------
# Application Settings
# --------------------------------------------
# Default LLM model
DEFAULT_MODEL="gpt-4o-mini"

# Max file upload size in MB
MAX_UPLOAD_SIZE_MB="50"

# Default chunk size for document processing
DEFAULT_CHUNK_SIZE="1000"

# Default chunk overlap
DEFAULT_CHUNK_OVERLAP="200"

# Internal API Key for server-to-server communication
# Generate with: openssl rand -base64 32
INTERNAL_API_KEY="your-internal-api-key-min-32-characters-long"

# --------------------------------------------
# Security Settings
# --------------------------------------------
# Enable virus scanning (requires ClamAV or similar)
# CLAMAV_HOST="localhost"
# CLAMAV_PORT="3310"
# ENABLE_VIRUS_SCAN="false"

# File upload restrictions
ALLOWED_FILE_TYPES="pdf,docx,txt,md,html"

# --------------------------------------------
# Email Configuration (for invitations and notifications)
# --------------------------------------------
# SMTP Configuration
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="your-smtp-user"
# SMTP_PASSWORD="your-smtp-password"
# SMTP_FROM="noreply@example.com"
# SMTP_SECURE="false"

# Or use a transactional email service
# RESEND_API_KEY="re_..."
# SENDGRID_API_KEY="SG..."

# --------------------------------------------
# Optional: Rate Limiting (Upstash Redis)
# --------------------------------------------
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# --------------------------------------------
# Optional: Analytics & Monitoring
# --------------------------------------------
# PostHog
# Get your API key from: https://app.posthog.com/project/settings
# NEXT_PUBLIC_POSTHOG_KEY="phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
# POSTHOG_API_KEY="phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"  # Server-side API key
# NEXT_PUBLIC_ENABLE_POSTHOG_DEV="false"  # Set to "true" to enable in development

# Sentry Error Tracking & Performance Monitoring
# Client-side DSN (public)
NEXT_PUBLIC_SENTRY_DSN=""

# Server-side DSN (can be same as client, or different for internal errors)
SENTRY_DSN=""

# Sentry Auth Token (for build-time source map upload)
# Get from: https://sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=""

# Optional: Sentry Organization and Project (for source maps)
# SENTRY_ORG="your-org"
# SENTRY_PROJECT="rag-starter-kit"

# Optional: Override release version (auto-detected from git by default)
# SENTRY_RELEASE="1.0.0"
# NEXT_PUBLIC_SENTRY_RELEASE="1.0.0"

# Optional: Disable Sentry build plugin (for local dev)
# SENTRY_DISABLE_BUILD_PLUGIN="true"

# --------------------------------------------
# S3-Compatible Object Storage (MinIO/AWS S3/R2)
# --------------------------------------------
# For local development with Docker, MinIO is automatically configured
# S3_ENDPOINT="http://localhost:9000"
# S3_ACCESS_KEY_ID="minioadmin"
# S3_SECRET_ACCESS_KEY="minioadmin"
# S3_REGION="us-east-1"
# S3_FORCE_PATH_STYLE="true"  # Required for MinIO

# Bucket names for different content types
# S3_BUCKET_DOCUMENTS="documents"
# S3_BUCKET_EXPORTS="exports"
# S3_BUCKET_ATTACHMENTS="attachments"

# MinIO Console (for local dev)
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001

# --------------------------------------------
# Real-time Collaboration (WebSocket/SSE)
# --------------------------------------------
# WebSocket server port (for standalone WebSocket server)
# WS_PORT=3001
# WS_HOST=0.0.0.0

# Application URL (used for CORS and WebSocket connections)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Internal API secret for server-to-server SSE broadcasts
# INTERNAL_SECRET="your-internal-secret-for-sse-broadcasts"

# --------------------------------------------
# SAML SSO (Optional)
# --------------------------------------------
# SAML_ISSUER=""
# SAML_CERT=""
# SAML_ENTRY_POINT=""
# SAML_CALLBACK_URL=""

# --------------------------------------------
# Development Settings
# --------------------------------------------
# Enable debug logging
# DEBUG="prisma:*"

# Disable Prisma query logging in dev
# PRISMA_HIDE_QUERY_LOG="true"
