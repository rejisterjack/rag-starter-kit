# ============================================
# RAG Starter Kit - Environment Configuration
# ============================================
#
# QUICK START:
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Get your FREE API keys:
#    - OpenRouter: https://openrouter.ai/keys
#    - Cloudinary: https://cloudinary.com/users/register_free
#    - Neon: https://console.neon.tech
#    - Upstash: https://console.upstash.com
#
# 3. Update the values below with your actual keys
#
# 4. Start the Next.js dev server:
#    pnpm dev
#
# ============================================

# REQUIRED: AI Provider API Keys
# ============================================

# OpenRouter - For Chat/LLM (Free models available)
# Get your free API key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here


# Fireworks AI - Fast inference for open-source models (Free models + $1 starter credits)
# Get your free API key: https://fireworks.ai
# FIREWORKS_API_KEY=your-fireworks-api-key-here

# Authentication (NextAuth.js v5)
# ============================================

# Generate a secure secret for JWT signing:
# openssl rand -base64 32
NEXTAUTH_SECRET=generate-a-32-character-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# Database (Neon - Serverless PostgreSQL with pgvector)
# ============================================

# Create a free Neon database: https://console.neon.tech
# After creating, enable pgvector: CREATE EXTENSION IF NOT EXISTS vector;
# Use the pooled connection string for runtime, direct for migrations
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/ragdb?sslmode=require

# File Storage (Cloudinary)
# ============================================

# Create a free Cloudinary account: https://cloudinary.com/users/register_free
# Find your credentials at: https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_FOLDER=rag-starter-kit

# Redis (Upstash - Serverless Redis)
# ============================================

# Create a free Upstash Redis database: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Background Jobs (Inngest)
# ============================================

# For local dev: pnpm inngest:dev (runs local dev server)
# For production: Use Inngest Cloud and register your sync endpoint
INNGEST_SIGNING_KEY=dev-signing-key-change-in-production
INNGEST_EVENT_KEY=dev-event-key-change-in-production

# Email (Resend)
# ============================================

# Create a free Resend account: https://resend.com
# Verify a sending domain, then generate an API key
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_TO_EMAIL=your-email@example.com
RESEND_WEBHOOK_SECRET=whsec_your-resend-webhook-secret

# Analytics (Plausible)
# ============================================

# For local dev, analytics are disabled.
# For production, use Plausible Cloud: https://plausible.io
# NEXT_PUBLIC_ANALYTICS_HOST=https://plausible.io
# NEXT_PUBLIC_ANALYTICS_SCRIPT_URL=https://plausible.io/js/script.js
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=your-domain.com

# Application
# ============================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_TELEMETRY_DISABLED=1

# Security (REQUIRED for Production)
# ============================================

# CSRF Protection Secret (min 32 chars)
# Generate: openssl rand -base64 32
CSRF_SECRET=change-this-to-a-32-character-secret-in-production

# Field-Level Encryption Master Key (min 32 chars)
# Generate: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=change-this-to-a-32-character-key-for-production

# OPTIONAL: Additional Configuration
# ============================================

# OAuth Providers (GitHub, Google) - for social login
# AUTH_GITHUB_ID=your-github-oauth-app-id
# AUTH_GITHUB_SECRET=your-github-oauth-app-secret
# AUTH_GOOGLE_ID=your-google-oauth-client-id
# AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# LLM Provider (openrouter | fireworks | openai | anthropic | ollama)
# LLM_PROVIDER=openrouter
# DEFAULT_MODEL=deepseek/deepseek-chat:free

# OpenAI API Key (fallback for embeddings)
# OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic API Key (optional, for Claude models)
# ANTHROPIC_API_KEY=sk-ant-...

# Embedding dimensions (must match your embedding model)
# 768 for Google text-embedding-004, 1536 for OpenAI text-embedding-3-small
# EMBEDDING_DIMENSIONS=768

# Ably Realtime (required for real-time features: presence, typing, cursors)
# ABLY_API_KEY=your-ably-api-key
