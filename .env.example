# ============================================
# RAG Starter Kit - Environment Configuration
# ============================================
#
# 🚀 QUICK START:
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Get your FREE API keys:
#    - OpenRouter: https://openrouter.ai/keys
#    - Google AI: https://aistudio.google.com/app/apikey
#
# 3. Update the values below with your actual keys
#
# 4. Start the stack:
#    docker-compose -f docker-compose.dev.yml up
#
# ============================================

# 🔴 REQUIRED: AI Provider API Keys (FREE)
# ============================================

# OpenRouter - For Chat/LLM (Free models available)
# Get your free API key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# Google AI Studio - For Embeddings (Free tier: 1,500 requests/day)
# Get your free API key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-ai-studio-key-here

# 🔐 Authentication (NextAuth.js v5)
# ============================================

# Generate a secure secret for JWT signing:
# openssl rand -base64 32
NEXTAUTH_SECRET=generate-a-32-character-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# 🗄️ Database (PostgreSQL + pgvector)
# ============================================

DATABASE_URL=postgresql://postgres:postgres@rag-db:5432/ragdb
DATABASE_URL_UNPOOLED=postgresql://postgres:postgres@rag-db:5432/ragdb

# 💾 Object Storage (MinIO)
# ============================================

S3_ENDPOINT=http://rag-minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_BUCKET_DOCUMENTS=documents
S3_BUCKET_EXPORTS=exports
S3_BUCKET_ATTACHMENTS=attachments

# ⚡ Background Jobs (Inngest)
# ============================================

INNGEST_SIGNING_KEY=dev-signing-key-change-in-production
INNGEST_EVENT_KEY=dev-event-key-change-in-production

# 💾 Redis (Rate Limiting, Caching & Presence)
# ============================================

REDIS_URL=redis://rag-redis:6379

# 📊 Analytics (Plausible - self-hosted in Docker)
# ============================================

NEXT_PUBLIC_ANALYTICS_HOST=http://localhost:8000
NEXT_PUBLIC_ANALYTICS_SCRIPT_URL=http://localhost:8000/js/script.js

# Plausible internal secret (generate: openssl rand -base64 48)
PLAUSIBLE_SECRET_KEY_BASE=your-plausible-secret-key-base-at-least-64-characters-long-change-in-production

# 🌐 Application
# ============================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_TELEMETRY_DISABLED=1

# ============================================
# OPTIONAL: Additional Configuration
# ============================================

# OAuth Providers (GitHub, Google) - for social login
# AUTH_GITHUB_ID=your-github-oauth-app-id
# AUTH_GITHUB_SECRET=your-github-oauth-app-secret
# AUTH_GOOGLE_ID=your-google-oauth-client-id
# AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# OpenAI API Key (fallback for embeddings)
# OPENAI_API_KEY=sk-your-openai-api-key

# PostHog Cloud (optional, for production analytics)
# NEXT_PUBLIC_POSTHOG_KEY=your-posthog-project-api-key
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
