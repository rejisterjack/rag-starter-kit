# ============================================================
# .dockerignore — keep the build context minimal
# Only files needed for: pnpm install + next build + prisma
# ============================================================

# ── Node / package managers ─────────────────────────────────
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.pnpm-store

# ── Next.js artefacts (rebuilt inside container) ────────────
.next
out
dist
build
*.tsbuildinfo
tsconfig.tsbuildinfo

# ── Test infrastructure ─────────────────────────────────────
coverage
.nyc_output
tests
playwright.config.ts
vitest.config.ts
lighthouserc.js
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__snapshots__

# ── Storybook ────────────────────────────────────────────────
.storybook
storybook-static

# ── Environment / secrets ────────────────────────────────────
.env
.env.local
.env.*.local
.env.development*
.env.test*
.env.production*
.env.docker
.env.*.example

# ── IDE / editor ─────────────────────────────────────────────
.idea
.vscode
*.swp
*.swo
*~

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db

# ── Git ──────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── Docker (never send compose/Dockerfile into itself) ───────
.docker
Dockerfile*
docker-compose*.yml
backups

# ── Documentation ────────────────────────────────────────────
*.md
docs
CHANGELOG.md
README.md
ROADMAP.md
CONTRIBUTING.md
CONTRIBUTORS.md
CODE_OF_CONDUCT.md
SECURITY.md
LICENSE

# ── Sentry configs (build plugins, not runtime) ──────────────
sentry.client.config.ts
sentry.edge.config.ts
sentry.server.config.ts

# ── Prisma (schema + prisma.config needed; migrations generated at deploy) ──
prisma/migrations
prisma/seed.ts

# ── Husky / lint tools ───────────────────────────────────────
.husky

# ── Performance / CI scripts ─────────────────────────────────
scripts
k8s
extensions
locales

# ── Misc caches / temp ───────────────────────────────────────
*.log
.cache
temp
tmp
.github
