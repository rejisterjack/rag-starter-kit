# ============================================
# RAG Starter Kit - Docker Development Environment
# BEST FREE SETUP: OpenRouter (Chat) + Google Gemini (Embeddings)
# ============================================

# --------------------------------------------
# Database (PostgreSQL + pgvector)
# --------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@rag-db:5432/ragdb
DATABASE_URL_UNPOOLED=postgresql://postgres:postgres@rag-db:5432/ragdb

# --------------------------------------------
# NextAuth.js Configuration
# --------------------------------------------
NEXTAUTH_SECRET=dev-secret-change-in-production
NEXTAUTH_URL=http://localhost:3000

# --------------------------------------------
# AI Provider Configuration (BEST FREE SETUP)
# --------------------------------------------

# 🔴 REQUIRED: OpenRouter API Key (for chat)
# Get FREE API key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-demo

# 🟡 REQUIRED: Google AI Studio API Key (for embeddings)
# Get FREE API key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-ai-studio-key

# LLM Provider Configuration
LLM_PROVIDER=openrouter

# Embedding Provider Configuration (Google = FREE high-quality)
EMBEDDING_PROVIDER=google

# Default Models (Best Free Options)
DEFAULT_MODEL=deepseek/deepseek-chat:free
EMBEDDING_MODEL=text-embedding-004

# Embedding Dimensions (768 for Google Gemini)
EMBEDDING_DIMENSIONS=768

# Similarity threshold for vector search (0.0 - 1.0)
DEFAULT_SIMILARITY_THRESHOLD=0.7
MAX_RETRIEVED_CHUNKS=5

# --------------------------------------------
# Ollama Configuration (optional fallback)
# --------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --------------------------------------------
# Application Settings
# --------------------------------------------
DEFAULT_CHUNK_SIZE=1000
DEFAULT_CHUNK_OVERLAP=200
MAX_UPLOAD_SIZE_MB=50
INTERNAL_API_KEY=internal-dev-key-change-in-production

# --------------------------------------------
# S3-Compatible Object Storage (MinIO)
# --------------------------------------------
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_BUCKET_DOCUMENTS=documents
S3_BUCKET_EXPORTS=exports
S3_BUCKET_ATTACHMENTS=attachments

# --------------------------------------------
# Inngest (Background Jobs)
# --------------------------------------------
INNGEST_SIGNING_KEY=dev-signing-key
INNGEST_EVENT_KEY=dev-event-key

# --------------------------------------------
# Redis (Optional - for rate limiting)
# --------------------------------------------
REDIS_URL=redis://redis:6379

# --------------------------------------------
# App URL
# --------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --------------------------------------------
# Development Settings
# --------------------------------------------
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1
