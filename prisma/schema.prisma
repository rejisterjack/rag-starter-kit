// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Authentication Models
// ============================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String    @unique
  emailVerified       DateTime?
  image               String?
  password            String?
  role                UserRole  @default(USER)

  // Active workspace for session
  activeWorkspaceId   String?

  // SSO fields
  samlId              String?   @unique

  accounts      Account[]
  sessions      Session[]

  // Relations
  chats             Chat[]
  documents         Document[]
  workspaceMembers  WorkspaceMember[]
  ownedWorkspaces   Workspace[]        @relation("WorkspaceOwner")
  createdApiKeys    ApiKey[]
  auditLogs         AuditLog[]
  rateLimits        RateLimit[]
  apiUsage          ApiUsage[]
  invitationsSent   WorkspaceInvitation[] @relation("InvitationSender")
  feedback          MessageFeedback[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([samlId])
  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

enum UserRole {
  USER
  ADMIN
}

// ============================================================================
// Workspace & Multi-tenancy Models
// ============================================================================

model Workspace {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  logoUrl     String?

  // SSO settings
  ssoEnabled  Boolean       @default(false)
  ssoDomain   String?

  // Settings stored as JSON
  settings    Json          @default("{}")

  // Relations
  ownerId     String
  owner       User          @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     WorkspaceMember[]
  invitations WorkspaceInvitation[]
  documents   Document[]
  chats       Chat[]
  apiKeys     ApiKey[]
  auditLogs   AuditLog[]
  samlConnection SamlConnection?
  tags        DocumentTag[]
  collections DocumentCollection[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([slug])
  @@index([ownerId])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String           @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole    @default(MEMBER)
  status      MemberStatus     @default(ACTIVE)
  joinedAt    DateTime         @default(now())

  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@map("workspace_members")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum MemberStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REMOVED
}

model WorkspaceInvitation {
  id            String        @id @default(cuid())
  workspaceId   String
  email         String
  role          WorkspaceRole @default(MEMBER)
  status        InviteStatus  @default(PENDING)
  token         String        @unique
  expiresAt     DateTime
  invitedById   String
  invitedAt     DateTime      @default(now())
  acceptedAt    DateTime?
  cancelledAt   DateTime?
  cancelledById String?

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy     User          @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
  @@index([token])
  @@index([status])
  @@map("workspace_invitations")
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

// ============================================================================
// Document Models
// ============================================================================

model Document {
  id          String           @id @default(cuid())
  name        String
  contentType String
  size        Int
  content     String?          @db.Text

  // Metadata
  sourceUrl   String?
  sourceType  String?
  metadata    Json             @default("{}")

  // Processing status
  status      DocumentStatus   @default(PENDING)

  // OCR-specific fields (for documents processed with OCR)
  /** Whether OCR was applied to this document */
  ocrProcessed     Boolean   @default(false)
  /** OCR confidence score (0-100) */
  ocrConfidence    Float?
  /** OCR language code used (e.g., 'eng', 'deu') */
  ocrLanguage      String?
  /** OCR processing time in milliseconds */
  ocrProcessingTimeMs Int?
  /** OCR engine mode used */
  ocrEngineMode    String?
  /** Page segmentation mode used */
  ocrPSM           String?
  /** Whether preprocessing was applied */
  ocrPreprocessing Boolean   @default(false)
  /** Error message if OCR failed */
  ocrError         String?

  // Relations
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String?
  workspace   Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  chunks      DocumentChunk[]
  images      DocumentImage[]
  ingestionJob IngestionJob?
  tags        DocumentTagsOnDocuments[]
  collections DocumentCollectionsOnDocuments[]

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
  @@index([workspaceId])
  @@index([status])
  @@index([ocrProcessed])
  @@index([ocrConfidence])
  @@map("documents")
}

model DocumentChunk {
  id          String     @id @default(cuid())
  documentId  String
  content     String     @db.Text
  index       Int
  start       Int
  end         Int
  page        Int?
  section     String?

  // Vector embedding (using pgvector extension)
  // Dimensions: 768 for Google Gemini, 1536 for OpenAI, 384 for local
  embedding   Unsupported("vector(768)")?

  document    Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  images      DocumentImage[]

  createdAt   DateTime   @default(now())

  @@index([documentId])
  @@map("document_chunks")
}

model IngestionJob {
  id          String        @id @default(cuid())
  documentId  String        @unique
  status      JobStatus     @default(QUEUED)
  progress    Int           @default(0)
  error       String?
  startedAt   DateTime?
  completedAt DateTime?

  document    Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("ingestion_jobs")
}

enum DocumentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

// ============================================================================
// Image Models (Multi-modal Support)
// ============================================================================

model DocumentImage {
  id          String     @id @default(cuid())
  documentId  String
  document    Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // Image metadata
  filename    String
  mimeType    String
  size        Int
  width       Int?
  height      Int?

  // Storage
  storageKey  String     // MinIO/S3 key
  storageUrl  String     // Public URL

  // OCR / Caption
  caption     String?    @db.Text
  ocrText     String?    @db.Text

  // OCR-specific metadata
  /** OCR confidence score (0-100) */
  ocrConfidence    Float?
  /** OCR language code used */
  ocrLanguage      String?
  /** OCR processing time in milliseconds */
  ocrProcessingTimeMs Int?
  /** Whether OCR preprocessing was applied */
  ocrPreprocessing Boolean @default(false)
  /** OCR bounding boxes as JSON */
  ocrBoundingBoxes Json?

  // Relations
  chunkId     String?
  chunk       DocumentChunk? @relation(fields: [chunkId], references: [id], onDelete: SetNull)
  pageNumber  Int?

  // Processing status
  status      ImageStatus @default(PENDING)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([documentId])
  @@index([chunkId])
  @@index([status])
  @@index([ocrConfidence])
  @@map("document_images")
}

model ImageEmbedding {
  id          String     @id @default(cuid())

  // Reference to the image
  imageId     String?
  imageUrl    String?    // For external images
  contentHash String     @unique // For caching

  // 512-dimensional CLIP embedding
  embedding   Unsupported("vector(512)")

  // Model info
  model       String     @default("Xenova/clip-vit-base-patch32")
  dimensions  Int        @default(512)

  createdAt   DateTime   @default(now())

  @@index([imageId])
  @@index([contentHash])
  @@map("image_embeddings")
}

enum ImageStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ============================================================================
// Chat Models
// ============================================================================

model Chat {
  id          String     @id @default(cuid())
  title       String     @default("New Chat")

  // AI model used for this chat (e.g., "deepseek/deepseek-chat:free")
  model       String?

  // Optional metadata for features like branching
  metadata    Json?      @default("{}")

  // Document processing tracking
  chunkCount  Int?

  // Relations
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  messages    Message[]
  share       ChatShare?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
  @@index([workspaceId])
  @@map("chats")
}

model Message {
  id          String    @id @default(cuid())
  chatId      String
  content     String    @db.Text
  role        MessageRole

  // Source citations
  sources     Json?

  // Token usage
  tokensUsed  Json?

  // Message metadata for features like editing
  metadata    Json?

  chat        Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  feedback    MessageFeedback[]

  createdAt   DateTime  @default(now())

  @@index([chatId])
  @@map("messages")
}

enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
}

// ============================================================================
// Message Feedback
// ============================================================================

model MessageFeedback {
  id          String    @id @default(cuid())
  messageId   String
  message     Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)

  // Feedback data
  rating      FeedbackRating
  comment     String?   @db.Text

  // Optional categorization
  categories  String[]  @default([])

  // User who gave feedback (may be anonymous)
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Metadata
  ipAddress   String?
  userAgent   String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
  @@index([rating])
  @@index([createdAt])
  @@map("message_feedback")
}

enum FeedbackRating {
  UP
  DOWN
}

// ============================================================================
// Chat Sharing
// ============================================================================

model ChatShare {
  id          String    @id @default(cuid())
  chatId      String    @unique
  chat        Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)

  // Share configuration
  isPublic    Boolean   @default(false)
  shareToken  String    @unique @default(cuid())

  // Access control
  allowComments Boolean @default(false)
  expiresAt   DateTime?

  // Tracking
  viewCount   Int       @default(0)
  lastViewedAt DateTime?

  // Creator
  createdBy   String

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([shareToken])
  @@index([isPublic])
  @@index([expiresAt])
  @@map("chat_shares")
}

// ============================================================================
// Document Organization (Tags & Collections)
// ============================================================================

model DocumentTag {
  id          String    @id @default(cuid())
  name        String
  color       String    @default("#6366f1")

  // Relations
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  documents   DocumentTagsOnDocuments[]

  createdAt   DateTime  @default(now())

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("document_tags")
}

model DocumentTagsOnDocuments {
  documentId  String
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tagId       String
  tag         DocumentTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  assignedAt  DateTime  @default(now())
  assignedBy  String?

  @@id([documentId, tagId])
  @@index([tagId])
  @@map("document_tags_on_documents")
}

model DocumentCollection {
  id          String    @id @default(cuid())
  name        String
  description String?   @db.Text

  // Relations
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  documents   DocumentCollectionsOnDocuments[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
  @@map("document_collections")
}

model DocumentCollectionsOnDocuments {
  documentId   String
  document     Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  collectionId String
  collection   DocumentCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  addedAt      DateTime  @default(now())
  addedBy      String?
  order        Int       @default(0)

  @@id([documentId, collectionId])
  @@index([collectionId])
  @@map("document_collections_on_documents")
}

// ============================================================================
// API Key Models
// ============================================================================

model ApiKey {
  id          String     @id @default(cuid())
  name        String
  keyHash     String     @unique
  keyPreview  String

  // Permissions
  permissions String[]   @default([])

  // Status
  status      ApiKeyStatus @default(ACTIVE)
  expiresAt   DateTime?
  lastUsedAt  DateTime?

  // Rate limiting
  rateLimit   Int        @default(100)

  // Relations
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  usage       ApiUsage[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
  @@index([workspaceId])
  @@index([keyHash])
  @@map("api_keys")
}

model ApiUsage {
  id                String   @id @default(cuid())

  // Request details
  endpoint          String
  method            String

  // Usage metrics
  tokensPrompt      Int      @default(0)
  tokensCompletion  Int      @default(0)
  tokensTotal       Int      @default(0)
  latencyMs         Int      @default(0)

  // Relations
  apiKeyId          String?
  apiKey            ApiKey?  @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  workspaceId       String?

  createdAt         DateTime @default(now())

  @@index([apiKeyId])
  @@index([userId])
  @@index([workspaceId])
  @@index([createdAt])
  @@index([workspaceId, createdAt]) // Composite index for analytics time-series queries
  @@map("api_usage")
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

// ============================================================================
// Audit & Security Models
// ============================================================================

model AuditLog {
  id          String       @id @default(cuid())
  event       AuditEvent
  severity    AuditSeverity @default(INFO)

  // Actor
  userId      String?
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Resource
  workspaceId String?
  workspace   Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Event data
  metadata    Json?
  resource    Json?
  changes     Json?
  error       String?

  // Request context
  ipAddress   String?
  userAgent   String?

  createdAt   DateTime     @default(now())

  @@index([userId])
  @@index([workspaceId])
  @@index([event])
  @@index([createdAt])
  @@map("audit_logs")
}

enum AuditEvent {
  // Authentication
  USER_LOGIN
  USER_LOGOUT
  USER_REGISTERED
  PASSWORD_CHANGED
  PASSWORD_RESET_REQUESTED

  // Workspace
  WORKSPACE_CREATED
  WORKSPACE_UPDATED
  WORKSPACE_DELETED
  WORKSPACE_SETTINGS_CHANGED

  // Members
  MEMBER_INVITED
  MEMBER_JOINED
  MEMBER_REMOVED
  MEMBER_ROLE_CHANGED

  // Documents
  DOCUMENT_UPLOADED
  DOCUMENT_DELETED
  DOCUMENT_UPDATED
  DOCUMENT_PROCESSED
  DOCUMENT_PROCESSING_FAILED

  // Chat
  CHAT_CREATED
  CHAT_UPDATED
  CHAT_DELETED
  CHAT_MESSAGE_SENT

  // API Keys
  API_KEY_CREATED
  API_KEY_REVOKED
  API_KEY_USED

  // Rate Limiting
  RATE_LIMIT_HIT

  // Security
  SUSPICIOUS_ACTIVITY
  PERMISSION_DENIED

  // Agentic Features
  AGENT_QUERY_CLASSIFIED
  AGENT_TOOL_CALLED
  MULTI_STEP_REASONING_STARTED
  CONVERSATION_BRANCHED

  // Voice
  VOICE_TRANSCRIPTION

  // Analytics
  READ_API_USAGE

  // Encryption
  ENCRYPTION_OPERATION
}

enum AuditSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

// ============================================================================
// Rate Limiting Models
// ============================================================================

model RateLimit {
  id        String   @id @default(cuid())

  // Identifier (IP, userId, or apiKey)
  key       String

  // Window tracking
  windowStart DateTime
  requests    Int      @default(0)

  // Type of limit
  type      String     @default("default")

  // Relations
  userId    String?
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([key, type, windowStart])
  @@index([key])
  @@index([userId])
  @@index([windowStart])
  @@map("rate_limits")
}

// ============================================================================
// Analytics Models
// ============================================================================

model RAGEvent {
  id              String   @id @default(cuid())

  // Query info
  query           String   @db.Text
  conversationId  String?

  // Context
  workspaceId     String?
  userId          String?

  // Retrieval info
  retrievedChunksData Json? @map("retrievedChunks")

  // Relations
  retrievedChunks RetrievedChunk[]

  // Response
  response        String?  @db.Text

  // Metrics
  latencyMs       Int
  totalTokens     Int      @default(0)
  model           String   @default("gpt-4o-mini")

  // Classification
  queryType       String?
  confidence      Float?
  reranked        Boolean  @default(false)

  createdAt       DateTime @default(now())

  @@index([workspaceId])
  @@index([userId])
  @@index([createdAt])
  @@map("rag_events")
}

model RetrievedChunk {
  id          String   @id @default(cuid())

  eventId     String
  event       RAGEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  chunkId     String
  documentId  String
  similarity  Float
  rank        Int

  createdAt   DateTime @default(now())

  @@index([eventId])
  @@index([documentId])
  @@map("retrieved_chunks")
}

model Metric {
  id        String   @id @default(cuid())
  type      String
  value     Float
  labels    Json     @default("{}")
  timestamp DateTime @default(now())

  @@index([type])
  @@index([timestamp])
  @@map("metrics")
}

// ============================================================================
// Integration Models
// ============================================================================

model IntegrationAccount {
  id                String   @id @default(cuid())

  // Provider info
  provider          String   // 'slack', 'notion', 'github', etc.
  providerAccountId String

  // OAuth tokens
  accessToken       String   @db.Text
  refreshToken      String?  @db.Text
  expiresAt         DateTime?

  // Scopes/permissions
  scope             String?

  // Relations
  userId            String
  workspaceId       String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("integration_accounts")
}

// ============================================================================
// Experiment Models (A/B Testing)
// ============================================================================

model Experiment {
  id            String          @id @default(cuid())
  name          String
  description   String?
  type          String          // 'prompt', 'model', 'retrieval', 'ui'
  status        ExperimentStatus @default(DRAFT)

  // Configuration
  variants      Json            // Array of variant configs
  trafficAllocation Json        // Percentage per variant

  // Relations
  workspaceId   String
  createdById   String

  startDate     DateTime?
  endDate       DateTime?

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([workspaceId])
  @@index([status])
  @@map("experiments")
}

enum ExperimentStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

model ExperimentEvent {
  id            String   @id @default(cuid())

  experimentId  String
  variantId     String

  // Event type
  eventType     String   // 'impression', 'conversion', 'custom'

  // User info
  userId        String?
  sessionId     String

  // Event data
  metadata      Json?

  createdAt     DateTime @default(now())

  @@index([experimentId])
  @@index([variantId])
  @@map("experiment_events")
}

// ============================================================================
// SAML SSO Models
// ============================================================================

model SamlConnection {
  id                String   @id @default(cuid())

  // Workspace relation
  workspaceId       String   @unique
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // IdP Configuration
  idpMetadata       String?  // Raw SAML metadata XML
  idpEntityId       String?
  idpSsoUrl         String?
  idpSloUrl         String?  // Single Logout URL
  idpCertificate    String?

  // SP Configuration
  spEntityId        String   @default("rag-starter-kit")
  spAcsUrl          String?

  // Security - privateKey is encrypted at rest using AES-256-GCM
  publicCertificate String?  // Our public cert for signing
  privateKey        String?  // Our private key (encrypted with ENCRYPTION_MASTER_KEY)

  // Settings
  allowIdpInitiated Boolean  @default(false)
  defaultRole       String   @default("MEMBER") // Default role for SAML users
  attributeMapping  Json     @default("{}") // Attribute mapping configuration

  // State
  enabled           Boolean  @default(true)
  lastLoginAt       DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([workspaceId])
  @@index([enabled])
  @@map("saml_connections")
}

// ============================================================================
// Webhook Models
// ============================================================================

model Webhook {
  id          String        @id @default(cuid())
  name        String
  url         String
  secret      String        // For HMAC signature (encrypted with ENCRYPTION_MASTER_KEY)
  events      String[]      // Events to subscribe to
  status      WebhookStatus @default(ACTIVE)

  // Relations
  workspaceId String
  createdById String
  deliveries  WebhookDelivery[]

  // Stats
  lastTriggeredAt DateTime?
  failureCount    Int       @default(0)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([workspaceId])
  @@index([status])
  @@map("webhooks")
}

enum WebhookStatus {
  ACTIVE
  PAUSED
  FAILED
}

model WebhookDelivery {
  id          String            @id @default(cuid())
  webhookId   String
  webhook     Webhook           @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  // Request details
  event       String
  payload     Json

  // Response details
  statusCode  Int?
  response    String?           @db.Text
  error       String?

  // Timing
  startedAt   DateTime          @default(now())
  completedAt DateTime?
  durationMs  Int?

  // Delivery status
  status      DeliveryStatus    @default(PENDING)
  retryCount  Int               @default(0)

  @@index([webhookId])
  @@index([status])
  @@index([startedAt])
  @@map("webhook_deliveries")
}

enum DeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  RETRYING
}
