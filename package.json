    "@types/socket.io": "^3.0.2",
    "@types/socket.io-client": "^3.0.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/postgres": "latest",
    "@xenova/transformers": "^2.17.2",
