    "artillery": "latest",
    "autoprefixer": "latest",
    "husky": "latest",
    "jsdom": "latest",
    "k6": "latest",
    "lint-staged": "latest",
    "mammoth": "latest",
    "postcss": "latest",
    "prisma": "latest",
    "storybook": "^10.3.1",
    "tailwindcss": "4.x",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "biome check --write"
    ],
    "*.{json,md,yml,yaml}": [
      "biome format --write"
    ]
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "pnpm": {
    "overrides": {
      "@types/pg": "8.11.11"
    }
  }
}
